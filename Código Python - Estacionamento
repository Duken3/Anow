      "source": [
        "num_veiculos = int(input(\"Quantos veículos entraram? \")) # Solicita ao usuário o número total de veículos\n",
        "\n",
        "veiculos_registrados = [] # Inicializa uma lista para armazenar os detalhes de cada veículo\n",
        "total_arrecadado = 0 # Inicializa o contador do total arrecadado\n",
        "\n",
        "# Loop para coletar informações e calcular o valor para cada veículo\n",
        "for i in range(num_veiculos):\n",
        "  print(f\"\\n--- Detalhes do Veículo {i+1} ---\")\n",
        "  tipo_veiculo = input(f\"Digite o tipo do veículo {i+1}: \") # Solicita o tipo do veículo\n",
        "  tempo_estacionado = int(input(f\"Digite o tempo estacionado em minutos para o veículo {i+1}: \")) # Solicita o tempo estacionado\n",
        "\n",
        "  valor_por_veiculo = 0 # Inicializa o valor a pagar para o veículo atual\n",
        "  # Condicionais para determinar o valor com base no tempo estacionado\n",
        "  if tempo_estacionado <= 15:\n",
        "    valor_por_veiculo = 0 # Gratuito até 15 minutos\n",
        "  elif tempo_estacionado <= 60:\n",
        "    valor_por_veiculo = 1.50 # R$1.50 entre 16 e 60 minutos\n",
        "  elif tempo_estacionado <= 120:\n",
        "    valor_por_veiculo = 2.50 # R$2.50 entre 61 e 120 minutos\n",
        "  else:\n",
        "    valor_por_veiculo = 3.50 # R$3.50 acima de 120 minutos\n",
        "\n",
        "  # Adiciona os detalhes do veículo à lista de veículos registrados\n",
        "  veiculos_registrados.append({\n",
        "      \"tipo\": tipo_veiculo,\n",
        "      \"tempo\": tempo_estacionado,\n",
        "      \"valor_a_pagar\": valor_por_veiculo\n",
        "  })\n",
        "  total_arrecadado += valor_por_veiculo # Acumula o valor arrecadado\n",
        "\n",
        "print(\"\\n--- Resumo --- \")\n",
        "# Loop para exibir o resumo de cada veículo\n",
        "for i, veiculo in enumerate(veiculos_registrados):\n",
        "  print(f\"Veículo {i+1}: Tipo: {veiculo['tipo']}, Tempo: {veiculo['tempo']} minutos, Valor a Pagar: R${veiculo['valor_a_pagar']:.2f}\")\n",
        "\n",
        "print(f\"\\nTotal arrecadado: R${total_arrecadado:.2f}\") # Exibe o total geral arrecadado"
      ],
